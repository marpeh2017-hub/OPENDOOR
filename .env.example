# ============================================================
# Urban Renewal OS – Environment Variables Template
# Copy to .env and fill in values
# ============================================================

# ---- App ----
NODE_ENV=development
APP_URL=http://localhost:3000
CRM_URL=http://localhost:3001
PORTAL_URL=http://localhost:3002
API_URL=http://localhost:4000

# ---- Database ----
DATABASE_URL=postgresql://postgres:password@localhost:5432/urban_renewal_os
DATABASE_SHADOW_URL=postgresql://postgres:password@localhost:5432/urban_renewal_os_shadow

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- RabbitMQ ----
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ---- Elasticsearch ----
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# ---- Auth ----
JWT_SECRET=change-me-to-a-random-secret-at-least-64-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-me-to-another-random-secret-at-least-64-chars
REFRESH_TOKEN_EXPIRES_IN=30d

# ---- AWS ----
AWS_REGION=il-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=urban-renewal-os-documents
AWS_S3_ENDPOINT=               # leave empty for real AWS, or use MinIO URL for local dev
AWS_CLOUDFRONT_URL=

# ---- Email (AWS SES) ----
SES_FROM_EMAIL=noreply@odg.co.il
SES_FROM_NAME=OpenDoor התחדשות עירונית

# ---- SMS ----
SMS_PROVIDER=inforu              # inforu | twilio
INFORU_USERNAME=
INFORU_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- WhatsApp Business API ----
WHATSAPP_PROVIDER=360dialog     # 360dialog | twilio
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Microsoft OAuth ----
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ---- DocuSign ----
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY_PATH=

# ---- AI ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Google Maps ----
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---- Monitoring ----
DATADOG_API_KEY=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- Feature Flags ----
ENABLE_AI_FEATURES=true
ENABLE_WHATSAPP=true
ENABLE_GIS=true
