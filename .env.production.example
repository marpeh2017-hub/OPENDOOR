# ── Copy this to Railway / Vercel environment variables ──────────────────────

# ── Database (Railway PostgreSQL — copy from Railway dashboard) ───────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/railway"

# ── JWT (generate with: openssl rand -base64 64) ─────────────────────────────
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="30d"

# ── App URLs (replace with your actual domains) ───────────────────────────────
NEXT_PUBLIC_API_URL="https://api.opendoor.co.il"
NEXT_PUBLIC_APP_URL="https://crm.opendoor.co.il"
PORTAL_URL="https://portal.opendoor.co.il"

# ── CORS origins ──────────────────────────────────────────────────────────────
CRM_URL="https://crm.opendoor.co.il"
PORTAL_URL="https://portal.opendoor.co.il"

# ── SMS / WhatsApp (Vonage) ───────────────────────────────────────────────────
VONAGE_API_KEY=""
VONAGE_API_SECRET=""
VONAGE_FROM_NUMBER="OpenDoor"

# ── File Storage (Cloudflare R2 or AWS S3) ────────────────────────────────────
S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="urban-renewal-prod"
S3_REGION="auto"

# ── ComSign Digital Signature ────────────────────────────────────────────────
COMSIGN_API_KEY=""
COMSIGN_API_URL="https://api.comsign.co.il"

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=4000
