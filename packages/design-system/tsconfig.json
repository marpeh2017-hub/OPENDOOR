{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "declaration": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tailwind.config.ts"],
  "exclude": ["node_modules"]
}
