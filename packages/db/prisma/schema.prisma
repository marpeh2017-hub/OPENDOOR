// ============================================================
// Urban Renewal OS – Prisma Schema (SQLite dev / Postgres prod)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Language {
  he
  en
  ru
  ar
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  CEO
  PROJECT_MANAGER
  RESIDENT_RELATIONS_MANAGER
  FIELD_AGENT
  LAWYER
  ARCHITECT
  ENGINEER
  DEVELOPER_REP
  MUNICIPALITY_USER
  EXTERNAL_CONSULTANT
  RESIDENT
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ProjectStage {
  DISCOVERY
  FEASIBILITY
  RESIDENT_ORGANIZATION
  SIGNATURES
  DEVELOPER_SELECTION
  PLANNING
  MUNICIPAL_APPROVAL
  PERMIT
  EVACUATION
  CONSTRUCTION
  DELIVERY
  POST_DELIVERY
}

enum LeadStatus {
  NEW
  CONTACTED
  MEETING_SCHEDULED
  INTERESTED
  NEGOTIATION
  SIGNED
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  WHATSAPP
  PHONE
  SOCIAL_MEDIA
  CAMPAIGN
  DOOR_TO_DOOR
  EVENT
  PARTNER
  OTHER
}

enum SignatureStatus {
  DRAFT
  SENT
  VIEWED
  PENDING
  SIGNED
  REJECTED
  EXPIRED
}

enum SignatureProvider {
  DOCUSIGN
  ADOBE_SIGN
  SIGNNOW
  COMSIGN
  MANUAL
}

enum DocumentCategory {
  CONTRACT
  ID_DOCUMENT
  LAND_REGISTRY
  POWER_OF_ATTORNEY
  PLANNING
  ENGINEERING
  FINANCIAL
  MUNICIPALITY
  MARKETING
  MEETING_MINUTES
  LEGAL
  PERMIT
  OTHER
}

enum DocumentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  ARCHIVED
}

enum TaskType {
  CALL
  MEETING
  SITE_VISIT
  SIGNATURE_FOLLOWUP
  LEGAL_REVIEW
  DOCUMENT_COLLECTION
  APPROVAL
  GENERAL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageChannel {
  WHATSAPP
  SMS
  EMAIL
  PUSH
  IN_APP
  PORTAL
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

enum ResidentSignatureStatus {
  NOT_CONTACTED
  CONTACTED
  INTERESTED
  SIGNED
  OBJECTING
  UNDECIDED
  UNREACHABLE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum VoteStatus {
  DRAFT
  ACTIVE
  CLOSED
  CANCELLED
}

enum AutomationTrigger {
  LEAD_CREATED
  RESIDENT_CREATED
  MEETING_COMPLETED
  SIGNATURE_SENT
  SIGNATURE_SIGNED
  PROJECT_STAGE_CHANGED
  DOCUMENT_UPLOADED
  DEADLINE_REACHED
  TASK_OVERDUE
  CUSTOM
}

enum AutomationActionType {
  CREATE_TASK
  SEND_WHATSAPP
  SEND_SMS
  SEND_EMAIL
  GENERATE_REPORT
  UPDATE_STATUS
  CREATE_NOTIFICATION
  WEBHOOK
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE
  READ
  UPDATE
  DELETE
  EXPORT
  DOWNLOAD
  SIGN
  APPROVE
  REJECT
  IMPERSONATE
}

// ============================================================
// CORE: MULTI-TENANCY
// ============================================================

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  domain       String?  @unique
  logoUrl      String?
  primaryColor String   @default("#2F9DA0")
  website      String?
  email        String?
  phone        String?
  settings     String   @default("{}")
  features     String   @default("{}")
  isActive     Boolean  @default(true)
  trialEndsAt  DateTime?
  plan         String   @default("starter")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users         User[]
  projects      Project[]
  leads         Lead[]
  documents     Document[]
  workflows     Workflow[]
  templates     CommunicationTemplate[]
  auditLogs     AuditLog[]
  campaigns     Campaign[]
  reports       SavedReport[]
  automations   Automation[]

  @@index([slug])
  @@map("tenants")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email       String?
  phone       String?
  nationalId  String?
  firstName   String
  lastName    String
  avatarUrl   String?
  role        UserRole
  language    Language @default(he)
  isActive    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  lastLoginAt DateTime?
  passwordHash     String?
  mfaEnabled       Boolean  @default(false)
  mfaSecret        String?
  notificationPrefs String @default("{\"email\":true,\"sms\":true,\"whatsapp\":true,\"push\":true,\"inApp\":true}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions            Session[]
  assignedTasks       Task[]          @relation("TaskAssignee")
  createdTasks        Task[]          @relation("TaskCreator")
  meetings            MeetingAttendee[]
  auditLogs           AuditLog[]
  projectMemberships  ProjectMember[]
  notifications       Notification[]
  createdDocuments    Document[]      @relation("DocumentCreator")

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  refreshToken String   @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

// ============================================================
// LEADS
// ============================================================

model Lead {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String
  phone       String?
  email       String?
  address     String?
  city        String?
  source      LeadSource @default(OTHER)
  campaignId  String?
  campaign    Campaign?  @relation(fields: [campaignId], references: [id])
  status      LeadStatus @default(NEW)
  score       Int        @default(0)
  notes       String?
  tags        String     @default("[]")
  assignedToId String?
  convertedToResidentId String? @unique
  convertedAt DateTime?
  language    Language   @default(he)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  activities  LeadActivity[]
  tasks       Task[]

  @@index([tenantId, status])
  @@index([tenantId, assignedToId])
  @@map("leads")
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        String
  note        String?
  metadata    String?
  createdAt   DateTime @default(now())
  createdById String?

  @@index([leadId])
  @@map("lead_activities")
}

// ============================================================
// PROJECTS & HIERARCHY
// ============================================================

model Project {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code        String
  name        String
  description String?
  city        String
  neighborhood String?
  address     String?
  coordinates String?

  status      ProjectStatus @default(ACTIVE)
  stage       ProjectStage  @default(DISCOVERY)

  startDate     DateTime?
  targetEndDate DateTime?
  actualEndDate DateTime?

  // Signature tracking
  totalUnits      Int   @default(0)
  signedUnits     Int   @default(0)
  signatureGoal   Int   @default(67)

  // Team
  projectManagerId String?
  lawyerId         String?
  architectId      String?
  developerRep     String?

  estimatedBudget Float?
  currency        String @default("ILS")
  settings        String @default("{}")
  tags            String @default("[]")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  complexes   Complex[]
  members     ProjectMember[]
  stages      ProjectStageHistory[]
  tasks       Task[]
  meetings    Meeting[]
  documents   Document[]
  campaigns   Campaign[]
  reports     SavedReport[]
  automations Automation[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, stage])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      UserRole
  addedAt   DateTime @default(now())

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectStageHistory {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage       ProjectStage
  enteredAt   DateTime     @default(now())
  exitedAt    DateTime?
  notes       String?
  changedById String?

  @@index([projectId])
  @@map("project_stage_history")
}

model Complex {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildings Building[]

  @@index([projectId])
  @@map("complexes")
}

model Building {
  id               String   @id @default(cuid())
  complexId        String
  complex          Complex  @relation(fields: [complexId], references: [id], onDelete: Cascade)
  address          String
  streetNumber     String?
  city             String?
  zipCode          String?
  floors           Int?
  totalApartments  Int?
  constructionYear Int?
  buildingClass    String?
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  apartments Apartment[]

  @@index([complexId])
  @@map("buildings")
}

model Apartment {
  id              String   @id @default(cuid())
  buildingId      String
  building        Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  apartmentNumber String
  floor           Int?
  sizeSqm         Float?
  rooms           Float?
  hasParking      Boolean  @default(false)
  hasStorage      Boolean  @default(false)
  hasBalcony      Boolean  @default(false)
  notes           String?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  residents Resident[]

  @@unique([buildingId, apartmentNumber])
  @@index([buildingId])
  @@map("apartments")
}

// ============================================================
// RESIDENTS
// ============================================================

model Resident {
  id          String   @id @default(cuid())
  tenantId    String

  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])

  firstName   String
  lastName    String
  nationalId  String?
  phone       String?
  phone2      String?
  email       String?

  ownershipPercentage Float @default(100)
  isPrimaryContact    Boolean @default(true)

  signatureStatus   ResidentSignatureStatus @default(NOT_CONTACTED)
  isObjecting       Boolean @default(false)
  objectionReason   String?
  riskScore         Int     @default(0)

  language              Language  @default(he)
  preferredChannel      MessageChannel @default(WHATSAPP)
  whatsappOptIn         Boolean   @default(false)
  smsOptIn              Boolean   @default(true)
  emailOptIn            Boolean   @default(true)
  doNotContact          Boolean   @default(false)
  doNotContactReason    String?

  portalUserId  String?  @unique
  portalEnabled Boolean  @default(false)

  notes     String?
  tags      String   @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents     ResidentDocument[]
  signatures    SignatureRequest[]
  meetings      MeetingAttendee[]
  tasks         Task[]
  messages      Message[]
  activityLog   ResidentActivity[]
  tickets       SupportTicket[]
  voteResponses VoteResponse[]

  @@index([apartmentId])
  @@index([signatureStatus])
  @@map("residents")
}

model ResidentActivity {
  id          String   @id @default(cuid())
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  type        String
  title       String
  note        String?
  metadata    String?
  createdAt   DateTime @default(now())
  createdById String?

  @@index([residentId])
  @@map("resident_activities")
}

// ============================================================
// SIGNATURES
// ============================================================

model SignatureRequest {
  id          String           @id @default(cuid())
  tenantId    String

  residentId  String
  resident    Resident         @relation(fields: [residentId], references: [id])

  documentId  String?
  document    Document?        @relation(fields: [documentId], references: [id])

  provider    SignatureProvider @default(MANUAL)
  externalId  String?
  status      SignatureStatus  @default(DRAFT)

  sentAt      DateTime?
  viewedAt    DateTime?
  signedAt    DateTime?
  rejectedAt  DateTime?
  expiresAt   DateTime?

  rejectionReason   String?
  signatureImageUrl String?
  metadata          String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([residentId])
  @@index([tenantId, status])
  @@map("signature_requests")
}

// ============================================================
// DOCUMENTS
// ============================================================

model Document {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  projectId   String?
  project     Project?         @relation(fields: [projectId], references: [id])

  category    DocumentCategory
  status      DocumentStatus   @default(DRAFT)

  title       String
  description String?
  fileName    String
  fileSize    Int              @default(0)
  mimeType    String           @default("application/octet-stream")
  s3Key       String           @default("")
  s3Bucket    String           @default("")

  version     Int              @default(1)
  parentId    String?
  parent      Document?        @relation("DocumentVersions", fields: [parentId], references: [id])
  versions    Document[]       @relation("DocumentVersions")

  ocrText     String?
  ocrStatus   String           @default("pending")
  language    Language         @default(he)
  isPublic    Boolean          @default(false)
  tags        String           @default("[]")
  expiresAt   DateTime?

  createdById String
  createdBy   User             @relation("DocumentCreator", fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  residentDocuments ResidentDocument[]
  signatureRequests SignatureRequest[]

  @@index([tenantId, category])
  @@index([tenantId, projectId])
  @@map("documents")
}

model ResidentDocument {
  id         String   @id @default(cuid())
  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  addedAt    DateTime @default(now())

  @@unique([residentId, documentId])
  @@map("resident_documents")
}

// ============================================================
// MEETINGS
// ============================================================

model Meeting {
  id          String   @id @default(cuid())
  tenantId    String

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])

  title       String
  description String?
  location    String?
  isVirtual   Boolean  @default(false)
  meetingUrl  String?
  startTime   DateTime
  endTime     DateTime?
  aiSummary   String?
  notes       String?
  status      String   @default("scheduled")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendees   MeetingAttendee[]
  tasks       Task[]

  @@index([tenantId, projectId])
  @@map("meetings")
}

model MeetingAttendee {
  id         String    @id @default(cuid())
  meetingId  String
  meeting    Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  residentId String?
  resident   Resident? @relation(fields: [residentId], references: [id])
  attended   Boolean?
  role       String?

  @@unique([meetingId, userId])
  @@unique([meetingId, residentId])
  @@map("meeting_attendees")
}

// ============================================================
// TASKS
// ============================================================

model Task {
  id          String       @id @default(cuid())
  tenantId    String

  type        TaskType     @default(GENERAL)
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)

  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById String?
  createdBy   User?        @relation("TaskCreator", fields: [createdById], references: [id])

  dueDate     DateTime?
  completedAt DateTime?

  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id])
  residentId  String?
  resident    Resident? @relation(fields: [residentId], references: [id])
  meetingId   String?
  meeting     Meeting?  @relation(fields: [meetingId], references: [id])

  blockedById String?
  blockedBy   Task?    @relation("TaskDependencies", fields: [blockedById], references: [id])
  blocking    Task[]   @relation("TaskDependencies")

  tags        String   @default("[]")
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, assigneeId, status])
  @@index([tenantId, projectId])
  @@map("tasks")
}

// ============================================================
// COMMUNICATIONS
// ============================================================

model Message {
  id          String                 @id @default(cuid())
  tenantId    String

  channel     MessageChannel
  direction   CommunicationDirection
  status      MessageStatus          @default(QUEUED)

  residentId  String?
  resident    Resident?              @relation(fields: [residentId], references: [id])
  toPhone     String?
  toEmail     String?

  subject     String?
  body        String
  templateId  String?
  template    CommunicationTemplate? @relation(fields: [templateId], references: [id])

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  failureReason String?
  externalId  String?
  metadata    String?

  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])

  createdAt   DateTime @default(now())

  @@index([tenantId, residentId])
  @@map("messages")
}

model CommunicationTemplate {
  id         String         @id @default(cuid())
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name       String
  channel    MessageChannel
  language   Language       @default(he)
  subject    String?
  body       String
  variables  String         @default("[]")
  isActive   Boolean        @default(true)
  isApproved Boolean        @default(false)
  waTemplateName String?
  waCategory     String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages   Message[]

  @@unique([tenantId, name, channel, language])
  @@map("communication_templates")
}

model Campaign {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])

  name        String
  description String?
  channel     MessageChannel
  status      String   @default("draft")

  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  totalRecipients Int @default(0)
  sent            Int @default(0)
  delivered       Int @default(0)
  read            Int @default(0)
  failed          Int @default(0)

  templateId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    Message[]
  leads       Lead[]

  @@index([tenantId, status])
  @@map("campaigns")
}

// ============================================================
// SUPPORT TICKETS
// ============================================================

model SupportTicket {
  id          String         @id @default(cuid())
  tenantId    String

  residentId  String?
  resident    Resident?      @relation(fields: [residentId], references: [id])

  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String?
  assigneeId  String?
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  replies     TicketReply[]

  @@index([tenantId, status])
  @@map("support_tickets")
}

model TicketReply {
  id               String        @id @default(cuid())
  ticketId         String
  ticket           SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId         String?
  authorResidentId String?
  body             String
  isInternal       Boolean @default(false)
  createdAt        DateTime @default(now())

  @@map("ticket_replies")
}

// ============================================================
// VOTING
// ============================================================

model Vote {
  id          String     @id @default(cuid())
  tenantId    String
  projectId   String?
  title       String
  description String?
  status      VoteStatus @default(DRAFT)
  type        String     @default("single_choice")
  options     String     // JSON array
  requiredParticipation Float @default(0.51)
  requiredMajority      Float @default(0.51)
  opensAt    DateTime?
  closesAt   DateTime?
  result     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  responses  VoteResponse[]

  @@index([tenantId, status])
  @@map("votes")
}

model VoteResponse {
  id              String   @id @default(cuid())
  voteId          String
  vote            Vote     @relation(fields: [voteId], references: [id], onDelete: Cascade)
  residentId      String
  resident        Resident @relation(fields: [residentId], references: [id])
  selectedOptions String   // JSON array of option IDs
  votedAt         DateTime @default(now())
  ipAddress       String?

  @@unique([voteId, residentId])
  @@map("vote_responses")
}

// ============================================================
// AUTOMATION ENGINE
// ============================================================

model Automation {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?          @relation(fields: [projectId], references: [id])
  name        String
  description String?
  isActive    Boolean           @default(true)
  trigger     AutomationTrigger
  triggerConfig String          @default("{}")
  runCount    Int @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  actions     AutomationAction[]

  @@index([tenantId, trigger, isActive])
  @@map("automations")
}

model AutomationAction {
  id           String              @id @default(cuid())
  automationId String
  automation   Automation          @relation(fields: [automationId], references: [id], onDelete: Cascade)
  order        Int
  type         AutomationActionType
  config       String
  delayMinutes Int                 @default(0)

  @@index([automationId])
  @@map("automation_actions")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================================
// REPORTING
// ============================================================

model SavedReport {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  name      String
  type      String
  config    String
  schedule  String?
  lastGeneratedAt DateTime?
  lastOutputUrl   String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("saved_reports")
}

// ============================================================
// WORKFLOWS
// ============================================================

model Workflow {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  stage     ProjectStage?
  isActive  Boolean  @default(true)
  nodes     String
  edges     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("workflows")
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  action    AuditAction
  entity    String
  entityId  String?
  changes   String?
  metadata  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  @@index([tenantId, userId])
  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
